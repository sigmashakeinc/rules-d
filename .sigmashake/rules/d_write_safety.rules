# d_write_safety.rules
# Technology: d | Capability: write

rule d-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "cast(void*)"
  MESSAGE "Blocked an unsafe pattern in d. Use the recommended best practices for 2025/2026."
}

rule d-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "std.c.stdio"
  MESSAGE "You are using an outdated API for d. Please upgrade to the newer API."
}
